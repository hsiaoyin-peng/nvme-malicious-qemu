+static bool mal_nvme_check_bounds(uint8_t cmd, NvmeNamespace *ns,
+        uint64_t slba, uint32_t nlb)
+{
+    uint64_t end_lba;
+    uint64_t max_lba;
+
+    if (slba > UINT64_MAX - nlb) {
+        return NVME_LBA_RANGE | NVME_DNR;
+    }
+    end_lba = slba + nlb;
+    max_lba = ns->size / ns->lbasz;
+
+    if (end_lba > max_lba)
+    {
+        //fprintf(stderr,
+        //        "[mal-nvme][CMD] op=%u reject/access slba=%" PRIu64 " nlb=%u end=%" PRIu64 " real_nsize=%" PRIu64 " lbasz=%zu max_lba=%" PRIu64 "\n", cmd, slba, nlb, end_lba, ns->size, ns->lbasz, max_lba);
+        return NVME_SUCCESS;
+    }
+
+    return NVME_LBA_RANGE | NVME_DNR;
+}
